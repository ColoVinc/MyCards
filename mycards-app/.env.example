# --- Database (Neon / PostgreSQL) ---
# In sviluppo puoi lasciarlo vuoto: Neon Launchpad (https://neon.new) crea
# un database temporaneo al primo `npm run dev` e compila .env.local.
# In produzione usa la connection string del tuo progetto Neon.
DATABASE_URL=

# --- Better Auth ---
# URL pubblico dell'app (es. https://mycards.vercel.app in produzione)
BETTER_AUTH_URL=http://localhost:3000
# Genera un secret: npx -y @better-auth/cli secret
BETTER_AUTH_SECRET=
